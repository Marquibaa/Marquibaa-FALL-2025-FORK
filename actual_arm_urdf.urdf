<?xml version="1.0"?>
<robot name="robotic_arm">

    <!-- ==================== BASE LINK ==================== -->
    <link name="base_link">
        <visual>
            <origin xyz="0 0 0.045" rpy="0 0 0"/>
            <geometry>
                <cylinder length="0.09" radius="0.15"/>
            </geometry>
        </visual>

        <collision>
            <origin xyz="0 0 0.045" rpy="0 0 0"/>
            <geometry>
                <cylinder length="0.09" radius="0.15"/>
            </geometry>
        </collision>

        <inertial>
            <mass value="1.0"/>
            <inertia ixx="0.01" ixy="0" ixz="0" iyy="0.01" iyz="0" izz="0.01"/>
        </inertial>
    </link>

    <!-- ==================== BASE ROTATING LINK ==================== -->
    <link name="base_rot">
        <visual>
            <geometry>
                <box size="0.07 0.078 0.052"/>
            </geometry>
        </visual>

        <collision>
            <geometry>
                <box size="0.07 0.078 0.052"/>
            </geometry>
        </collision>

        <inertial>
            <mass value="0.5"/>
            <inertia ixx="0.005" ixy="0" ixz="0" iyy="0.005" iyz="0" izz="0.005"/>
        </inertial>
    </link>

    <joint name="base_joint" type="revolute">
        <parent link="base_link"/>
        <child link="base_rot"/>
        <origin xyz="0 0 0.116" rpy="0 0 0"/>
        <axis xyz="0 0 -1"/>
        <limit lower="-3.14" upper="3.14"/>
    </joint>

    <!-- ==================== LOWER ARM ==================== -->
    <link name="lower_arm">
        <visual>
            <origin xyz="0 0 0.12375"/>
            <geometry>
                <cylinder length="0.2475" radius="0.07"/>
            </geometry>
        </visual>

        <collision>
            <origin xyz="0 0 0.12375"/>
            <geometry>
                <cylinder length="0.2475" radius="0.07"/>
            </geometry>
        </collision>

        <inertial>
            <mass value="0.4"/>
            <inertia ixx="0.004" ixy="0" ixz="0" iyy="0.004" iyz="0" izz="0.004"/>
        </inertial>
    </link>

    <joint name="shoulder_joint" type="revolute">
        <parent link="base_rot"/>
        <child link="lower_arm"/>
        <origin xyz="0 0 0.026"/>
        <axis xyz="1 0 0"/>
        <limit lower="-1.57" upper="1.57"/>
    </joint>

    <!-- ==================== CENTER ARM ==================== -->
    <link name="center_arm">
        <visual>
            <origin xyz="0 0 0.08625"/>
            <geometry>
                <cylinder length="0.1725" radius="0.055"/>
            </geometry>
        </visual>

        <collision>
            <origin xyz="0 0 0.08625"/>
            <geometry>
                <cylinder length="0.1725" radius="0.055"/>
            </geometry>
        </collision>

        <inertial>
            <mass value="0.3"/>
            <inertia ixx="0.003" ixy="0" ixz="0" iyy="0.003" iyz="0" izz="0.003"/>
        </inertial>
    </link>

    <joint name="elbow_joint" type="revolute">
        <parent link="lower_arm"/>
        <child link="center_arm"/>
        <origin xyz="0 0 0.2475"/>
        <axis xyz="1 0 0"/>
        <limit lower="-2.1" upper="2.1"/>
    </joint>

    <!-- ==================== UPPER ARM ==================== -->
    <link name="upper_arm">
        <visual>
            <origin xyz="0 0 0.05375"/>
            <geometry>
                <cylinder length="0.1075" radius="0.05"/>
            </geometry>
        </visual>

        <collision>
            <origin xyz="0 0 0.05375"/>
            <geometry>
                <cylinder length="0.1075" radius="0.05"/>
            </geometry>
        </collision>

        <inertial>
            <mass value="0.2"/>
            <inertia ixx="0.002" ixy="0" ixz="0" iyy="0.002" iyz="0" izz="0.002"/>
        </inertial>
    </link>

    <joint name="wrist_joint_1" type="revolute">
        <parent link="center_arm"/>
        <child link="upper_arm"/>
        <origin xyz="0 0 0.1725"/>
        <axis xyz="1 0 0"/>
        <limit lower="-2.1" upper="2.1"/>
    </joint>

    <!-- ==================== GRIPPER ==================== -->
    <link name="gripper">
        <visual>
            <origin xyz="0 0 0.0125"/>
            <geometry>
                <box size="0.2 0.05 0.025"/>
            </geometry>
        </visual>

        <collision>
            <origin xyz="0 0 0.0125"/>
            <geometry>
                <box size="0.2 0.05 0.025"/>
            </geometry>
        </collision>

        <inertial>
            <mass value="0.1"/>
            <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/>
        </inertial>
    </link>

    <joint name="wrist_joint_2" type="revolute">
        <parent link="upper_arm"/>
        <child link="gripper"/>
        <origin xyz="0 0 0.1075"/>
        <axis xyz="0 0 1"/>
        <limit lower="-3.14" upper="3.14"/>
    </joint>

</robot>
